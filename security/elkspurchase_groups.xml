<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Privilege: appears as a row on the User form Access Rights tab -->
        <record id="res_groups_privilege_elkspurchase" model="res.groups.privilege">
            <field name="name">Elks Purchase Approvals</field>
            <field name="category_id" ref="base.module_category_supply_chain"/>
            <field name="sequence">70</field>
        </record>

        <!-- Elks Purchase Approval Groups -->
        <record id="group_elks_committee" model="res.groups">
            <field name="name">Purchase Requester</field>
            <field name="privilege_id" ref="res_groups_privilege_elkspurchase"/>
            <field name="comment">
                Can create and submit PO requests for Board review.
            </field>
            <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
        </record>

        <record id="group_elks_trustee" model="res.groups">
            <field name="name">Board Member</field>
            <field name="privilege_id" ref="res_groups_privilege_elkspurchase"/>
            <field name="sequence">5</field>
            <field name="comment">
                Can approve PO requests at the Board level and
                advance them to Floor Vote.
            </field>
            <field name="implied_ids" eval="[(4, ref('group_elks_committee'))]"/>
        </record>

        <record id="group_elks_secretary" model="res.groups">
            <field name="name">Secretary / Floor Vote Recorder</field>
            <field name="privilege_id" ref="res_groups_privilege_elkspurchase"/>
            <field name="sequence">10</field>
            <field name="comment">
                Can record Floor Vote results on purchase requests.
                Typically the Lodge Secretary.
            </field>
            <field name="implied_ids" eval="[(4, ref('group_elks_trustee'))]"/>
        </record>

    </data>
</odoo>
